[alias]
  addf = "!git ls-files -m -o --exclude-standard | fzf --print0 -m | xargs -0 -t -o git add"
  rbr = "!f() { git pull --rebase=interactive origin $1; }; f"
  rbrr = "!f() { git pull --rebase=interactive $1 $2; }; f"
  logs = "!git log --oneline | head -n 5"
  up = "!f() { git pull -X theirs origin $1; }; f"
[pull]
	rebase = true
[oh-my-zsh]
  hide-status = 1
  hide-dirty = 1
  hide-status = 0
  hide-dirty = 0
  hide-status = 0
  hide-dirty = 0
[core]
  editor = nvim
	longpaths = true
[diff]
  tool = nvimdiff
[difftool]
  prompt = false
[rebase]
  autoSquash = true
[init]
	defaultBranch = main
[credential]
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
[credential "azrepos:org/1esgitops"]
	username = popatudor@microsoft.com
